{
    "name": "@navikt/nav-dekoratoren-moduler",
    "version": "4.0.0-beta-analytics-types.3",
    "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937",
    "description": "Moduler til nav-dekoratoren",
    "author": "NAVIKT",
    "license": "MIT",
    "repository": "navikt/nav-dekoratoren-moduler",
    "main": "csr/index.js",
    "module": "csr/index.js",
    "source": "src/csr/index.tsx",
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "start": "pnpm run --parallel --filter . \"/^start:.*/\"",
        "start:csr": "rollup -c rollup.config.csr.mjs -w",
        "start:ssr": "rollup -c rollup.config.ssr.mjs -w",
        "build": "pnpm run --parallel --filter . \"/^build:.*/\"",
        "build:csr": "rollup -c rollup.config.csr.mjs",
        "build:ssr": "rollup -c rollup.config.ssr.mjs",
        "lint": "pnpm run lint:moduler && pnpm run lint:example-csr && pnpm run lint:example-next",
        "lint:moduler": "eslint src/ && tsc --noEmit",
        "lint:example-csr": "pnpm -C examples/csr run lint",
        "lint:example-next": "pnpm -C examples/next-app-router run lint",
        "test": "vitest run",
        "prepare": "husky",
        "predeploy": "cd example && pnpm install && pnpm run build",
        "publish:beta": "pnpm run build && npm version prerelease --preid beta && npm publish --access public --tag beta"
    },
    "files": [
        "csr",
        "ssr"
    ],
    "browser": {
        "child_process": false
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "peerDependencies": {
        "html-react-parser": ">=5.x",
        "react": ">=17.x"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    },
    "dependencies": {
        "@navikt/analytics-types": "0.0.8",
        "csp-header": "6.3.1",
        "js-cookie": "3.0.5"
    },
    "devDependencies": {
        "@eslint/js": "catalog:",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@rollup/plugin-typescript": "12.3.0",
        "@types/js-cookie": "3.0.6",
        "@types/jsdom": "21.1.7",
        "@types/mock-fs": "4.13.4",
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@typescript-eslint/eslint-plugin": "catalog:",
        "@typescript-eslint/parser": "catalog:",
        "@vitest/eslint-plugin": "1.6.12",
        "eslint": "catalog:",
        "eslint-plugin-react": "catalog:",
        "globals": "catalog:",
        "husky": "9.1.7",
        "jsdom": "26.1.0",
        "mock-fs": "5.5.0",
        "prettier": "3.8.1",
        "rollup": "4.59.0",
        "rollup-plugin-dts": "6.4.0",
        "tslib": "2.8.1",
        "typescript": "catalog:",
        "vitest": "4.1.0",
        "vitest-fetch-mock": "0.4.5"
    }
}
